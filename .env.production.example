# Values for the shared-host `.env` on rimboai.com
# (copy into server .env — do not commit real secrets)

APP_NAME=RIMBOAI
APP_ENV=production
APP_DEBUG=false
APP_URL=https://rimboai.com
FORCE_HTTPS=true

# Optional cookie domain across www / apex
SESSION_DOMAIN=.rimboai.com

# Frontend: keep empty (relative URLs). Rebuild with this only if you ever host the SPA elsewhere.
VITE_APP_URL=
